---
interface Props {
	initialSpeed: number;
	initialRoadAngle: number;
}

const { initialSpeed, initialRoadAngle } = Astro.props;
---

<section class="game-scene" aria-label="Animazione corsa">
	<div class="scene-wrapper" data-speed={String(initialSpeed)} data-angle={String(initialRoadAngle)}>
		{/* Sky layer (behind clouds) */}
		<svg class="sky-svg" viewBox="0 0 1000 400" preserveAspectRatio="none">
			<defs>
				<linearGradient id="sky-gradient" x1="0" y1="0" x2="0" y2="1">
					<stop offset="0%" stop-color="#7dd3fc" />
					<stop offset="60%" stop-color="#bae6fd" />
					<stop offset="100%" stop-color="#e0f2fe" />
				</linearGradient>
			</defs>
			<polygon id="sky-fill" fill="url(#sky-gradient)" points="" />
		</svg>

		{/* Scrolling elements container (clouds, stars) - between sky and road */}
		<div id="scrolling-elements" class="scrolling-elements" />

		{/* Road layer (in front of clouds) */}
		<svg class="road-svg" viewBox="0 0 1000 400" preserveAspectRatio="none">
			<polyline id="road-path" class="road-path" points="" />
			{/* Ground fill below road */}
			<polygon id="ground-fill" class="ground-fill" points="" />
		</svg>

		<img
			src="/running-stickman.gif"
			alt="Stickman in corsa"
			class="runner-gif"
			id="runner-gif"
		/>
	</div>
</section>
