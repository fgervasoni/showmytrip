---
import type {RunActivity, Units} from '../../types';
import {formatDuration, formatPace, formatDate} from '../../lib/run-helpers';
import {t, type Locale} from '../../lib/i18n';
import timerIcon from 'lucide-static/icons/timer.svg?raw';

interface BestEffort {
    name: string;
    distance: number;
    moving_time: number;
    elapsed_time: number;
    start_date: string;
    activity_id: number;
    activity_name?: string;
    average_heartrate?: number;
}

interface Props {
    activities: RunActivity[];
    bestEfforts: Array<Record<string, unknown>>;
    locale: Locale;
    units: Units;
}

const {activities, bestEfforts, locale, units} = Astro.props;

// Map Strava best_efforts names to our labels (adapt to units)
const isMetric = units === 'km';

const EFFORT_MAP: { stravaName: string; label: string; meters: number }[] = isMetric
    ? [
        {stravaName: '1/2 mile', label: '800m', meters: 800},
        {stravaName: '1K', label: '1 km', meters: 1000},
        {stravaName: '5K', label: '5K', meters: 5000},
        {stravaName: '10K', label: '10K', meters: 10000},
        {stravaName: 'Half-Marathon', label: locale === 'it' ? 'Mezza maratona' : 'Half marathon', meters: 21097},
        {stravaName: 'Marathon', label: locale === 'it' ? 'Maratona' : 'Marathon', meters: 42195},
    ]
    : [
        {stravaName: '1/2 mile', label: '½ mile', meters: 800},
        {stravaName: '1 mile', label: '1 mile', meters: 1609},
        {stravaName: '5K', label: '3.1 mile', meters: 5000},
        {stravaName: '10K', label: '6.2 mile', meters: 10000},
        {stravaName: 'Half-Marathon', label: locale === 'it' ? 'Mezza maratona' : 'Half marathon', meters: 21097},
        {stravaName: 'Marathon', label: locale === 'it' ? 'Maratona' : 'Marathon', meters: 42195},
    ];

interface BestTimeEntry {
    label: string;
    meters: number;
    movingTime: number;
    activityId: number;
    activityName: string;
    startDate: string;
    averageHeartrate?: number;
    source: 'effort' | 'activity';
}

// Parse best efforts from Strava
const efforts = (bestEfforts as unknown as BestEffort[]).filter(e => e.distance > 0 && e.moving_time > 0);

// Group by distance name, keep only the fastest
const bestByName = new Map<string, BestTimeEntry>();

for (const mapping of EFFORT_MAP) {
    // Find all efforts matching this Strava name
    const matching = efforts.filter(e => e.name === mapping.stravaName);
    if (matching.length === 0) continue;

    // Pick the fastest
    const fastest = matching.reduce((best, e) => e.moving_time < best.moving_time ? e : best, matching[0]);

    bestByName.set(mapping.stravaName, {
        label: mapping.label,
        meters: mapping.meters,
        movingTime: fastest.moving_time,
        activityId: fastest.activity_id,
        activityName: fastest.activity_name ?? '',
        startDate: fastest.start_date,
        averageHeartrate: fastest.average_heartrate,
        source: 'effort',
    });
}

// Also check direct activity matches (for distances not in Strava best_efforts)
const EXTRA_DISTANCES = isMetric
    ? [
        {meters: 1_500, tolerance: 0.12, label: '1.5 km'},
        {meters: 50_000, tolerance: 0.05, label: '50K'},
    ]
    : [
        {meters: 50_000, tolerance: 0.05, label: '50K (31 mi)'},
    ];

const distActivities = activities.filter((a) => a.distance && a.distance > 0 && a.moving_time && a.moving_time > 0);

for (const race of EXTRA_DISTANCES) {
    const minDist = race.meters * (1 - race.tolerance);
    const maxDist = race.meters * (1 + race.tolerance);
    const matching = distActivities.filter((a) => a.distance! >= minDist && a.distance! <= maxDist);
    if (matching.length === 0) continue;

    const best = matching.reduce<RunActivity>((b, a) => {
        const paceA = a.moving_time! / a.distance!;
        const paceB = b.moving_time! / b.distance!;
        return paceA < paceB ? a : b;
    }, matching[0]);

    const key = `extra_${race.meters}`;
    bestByName.set(key, {
        label: race.label,
        meters: race.meters,
        movingTime: best.moving_time!,
        activityId: best.id ?? 0,
        activityName: best.name ?? '',
        startDate: best.start_date ?? '',
        averageHeartrate: best.average_heartrate,
        source: 'activity',
    });
}

// Sort by distance and convert to array
const bests = [...bestByName.values()].sort((a, b) => a.meters - b.meters);
const hasBests = bests.length > 0;

const splitsLoadingLabel = locale === 'it' ? 'Caricamento split…' : 'Loading splits…';
const splitsErrorLabel = locale === 'it' ? 'Errore nel caricamento split' : 'Error loading splits';
const splitLabel = locale === 'it' ? 'Split' : 'Split';
const closeLabel = locale === 'it' ? 'Chiudi' : 'Close';
const bestSegmentLabel = locale === 'it' ? 'Segmento best effort' : 'Best effort segment';
const viewSplitsLabel = locale === 'it' ? 'Vedi split' : 'View splits';
const paceLabel = t(locale, 'pace');
const hrLabel = t(locale, 'heartRate');
const unitsValue = units;

// Serialise bests for client script (activityId → meters mapping)
const bestsData = JSON.stringify(bests.map(b => ({activityId: b.activityId, meters: b.meters, label: b.label})));
---

{hasBests && (
<div class="mt-8">
    <h3 class="section-title">
        <span class="app-icon" set:html={timerIcon}/> {t(locale, 'bestTimes')}
    </h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {bests.map((b) => (
                <article
                        class="card record-card"
                        data-activity-id={b.activityId}
                        data-target-meters={b.meters}
                        data-label={b.label}
                        data-activity-name={b.activityName}
                >
                    <h3 class="text-sm font-medium text-gray-500 dark:text-gray-400">
                        {b.label}
                        {b.source === 'effort' && (
                                <span class="ml-1 text-[10px] text-emerald-500"
                                      title={locale === 'it' ? 'Miglior segmento in una attività' : 'Best segment within an activity'}></span>
                        )}
                    </h3>
                    <p class="text-xl font-bold text-gray-800 dark:text-gray-100 mt-1">{formatDuration(b.movingTime)}</p>
                    <div class="mt-1.5 text-xs text-gray-500 dark:text-gray-400 space-y-0.5">
                        <div>{t(locale, 'pace')}: {formatPace(b.meters, b.movingTime, units)}</div>
                        {b.averageHeartrate && (
                                <div>{t(locale, 'heartRate')}: {Math.round(b.averageHeartrate)} bpm</div>
                        )}
                    </div>
                    <span class="record-meta">{b.activityName} — {formatDate(b.startDate)}</span>
                    <button
                            type="button"
                            class="splits-btn mt-2 inline-flex items-center gap-1.5 text-xs font-medium text-orange-600 dark:text-orange-400 hover:text-orange-700 dark:hover:text-orange-300 transition-colors cursor-pointer"
                            data-splits-btn
                            data-activity-id={b.activityId}
                            data-target-meters={b.meters}
                            data-label={b.label}
                            data-activity-name={b.activityName}
                            aria-label={`${viewSplitsLabel} – ${b.label}`}
                    >
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M9 17V7m0 10l-3-3m3 3l3-3M15 7v10m0-10l-3 3m3-3l3 3"/>
                        </svg>
                        {viewSplitsLabel}
                    </button>
                </article>
        ))}
    </div>
</div>
    )}

{/* Modal – directly in DOM, hidden by default */}
<div id="splits-modal" class="fixed inset-0 z-[9999] hidden" role="dialog" aria-modal="true"
     style="position:fixed;top:0;left:0;right:0;bottom:0;">
    <div id="splits-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <div class="absolute inset-0 flex items-start justify-center pt-[10vh] p-4 pointer-events-none overflow-y-auto">
        <div id="splits-panel"
             class="pointer-events-auto bg-white dark:bg-gray-800 rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-700 w-full max-w-lg max-h-[80vh] flex flex-col overflow-hidden my-auto">
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 dark:border-gray-700 flex-shrink-0">
                <div>
                    <h3 id="splits-modal-title"
                        class="font-semibold text-gray-800 dark:text-gray-100 text-base"></h3>
                    <p id="splits-modal-subtitle" class="text-xs text-gray-400 mt-0.5"></p>
                </div>
                <button id="splits-close-btn" type="button"
                        class="p-1.5 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors"
                        aria-label={closeLabel}>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <div id="splits-modal-body" class="px-5 py-4 overflow-y-auto flex-1"></div>
        </div>
    </div>
</div>

{/* Inline script: pass server-side vars to window for the module script */}
<script is:inline define:vars={{
    unitsValue,
    splitsLoadingLabel,
    splitsErrorLabel,
    splitLabel,
    paceLabel,
    hrLabel,
    closeLabel,
    bestSegmentLabel
}}>
    window.__timeBestsConfig = {
        unitsValue: unitsValue,
        splitsLoadingLabel: splitsLoadingLabel,
        splitsErrorLabel: splitsErrorLabel,
        splitLabel: splitLabel,
        paceLabel: paceLabel,
        hrLabel: hrLabel,
        closeLabel: closeLabel,
        bestSegmentLabel: bestSegmentLabel
    };
</script>

{/* Module script: runs once, re-inits on every astro:page-load */}
<script>
    function initTimeBests() {
        const cfg = (window as any).__timeBestsConfig;
        if (!cfg) return;

        const btns = document.querySelectorAll<HTMLElement>('[data-splits-btn]');
        if (!btns.length) return;

        // Remove previous escape listener
        if ((window as any).__timeBestsEscHandler) {
            document.removeEventListener('keydown', (window as any).__timeBestsEscHandler);
        }

        // Move modal to body root so it overlays everything
        const modalEl = document.getElementById('splits-modal');
        if (modalEl && modalEl.parentElement !== document.body) {
            document.body.appendChild(modalEl);
        }

        const { unitsValue, splitsLoadingLabel, splitsErrorLabel, splitLabel, paceLabel, bestSegmentLabel } = cfg;
        const KM_TO_MI = 0.621371;
        const cache: Record<string, any[]> = {};

        const modal = document.getElementById('splits-modal');
        const backdrop = document.getElementById('splits-backdrop');
        const closeBtn = document.getElementById('splits-close-btn');
        const titleEl = document.getElementById('splits-modal-title');
        const subtitleEl = document.getElementById('splits-modal-subtitle');
        const bodyEl = document.getElementById('splits-modal-body');

        function openModal() {
            if (!modal) return;
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            if (!modal) return;
            modal.classList.add('hidden');
            document.body.style.overflow = '';
        }

        backdrop?.addEventListener('click', closeModal);
        closeBtn?.addEventListener('click', closeModal);

        const onEscape = (e: KeyboardEvent) => { if (e.key === 'Escape') closeModal(); };
        document.addEventListener('keydown', onEscape);
        (window as any).__timeBestsEscHandler = onEscape;

        function formatSplitPace(seconds: number, u: string) {
            const min = Math.floor(seconds / 60);
            const sec = Math.round(seconds % 60);
            return min + ':' + String(sec).padStart(2, '0') + ' /' + u;
        }

        function renderSplits(splits: any[], targetMeters: number) {
            if (!splits || splits.length === 0) {
                return '<p class="text-sm text-gray-400 py-4 text-center">No splits available</p>';
            }

            const totalActivityDist = splits.reduce((s: number, sp: any) => s + (sp.distance || 1000), 0);
            const isBestEffort = targetMeters < totalActivityDist * 0.95;
            let highlightStart = -1;
            let highlightEnd = -1;

            if (isBestEffort && targetMeters > 0) {
                let fullSplitsCount = splits.length;
                const lastSplit = splits[splits.length - 1];
                if (lastSplit && (lastSplit.distance || 1000) < 900) {
                    fullSplitsCount = splits.length - 1;
                }
                const nSplitsNeeded = Math.ceil(targetMeters / 1000);
                let bestWindowTime = Infinity;
                let bestStart = 0;

                for (let i = 0; i <= fullSplitsCount - nSplitsNeeded; i++) {
                    let windowTime = 0;
                    for (let j = i; j < i + nSplitsNeeded; j++) {
                        windowTime += splits[j].moving_time;
                    }
                    if (windowTime < bestWindowTime) {
                        bestWindowTime = windowTime;
                        bestStart = i;
                    }
                }
                highlightStart = bestStart;
                highlightEnd = bestStart + nSplitsNeeded - 1;
            }

            let html = '';
            if (isBestEffort) {
                html += '<div class="flex items-center gap-2 mb-3 text-xs"><span class="inline-block w-3 h-1.5 rounded bg-emerald-400"></span><span class="text-gray-500 dark:text-gray-400">' + bestSegmentLabel + '</span></div>';
            }

            html += '<div class="space-y-0.5">';
            html += '<div class="grid grid-cols-4 text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-1.5 px-2">';
            html += '<span>' + splitLabel + '</span><span class="text-center">' + paceLabel + '</span><span class="text-center">BPM</span><span class="text-right">⏱</span>';
            html += '</div>';

            let cumTime = 0;
            for (let idx = 0; idx < splits.length; idx++) {
                const s = splits[idx];
                const dist = s.distance || 1000;
                const distKm = dist / 1000;
                const pacePerKm = s.moving_time / distKm;
                const pace = unitsValue === 'mi' ? pacePerKm / KM_TO_MI : pacePerKm;
                const hr = s.average_heartrate ? Math.round(s.average_heartrate) + '' : '-';
                const isLast = s.split === splits.length && dist < 900;
                cumTime += s.moving_time;
                const cumMin = Math.floor(cumTime / 60);
                const cumSec = Math.floor(cumTime % 60);
                const cumStr = cumMin + ':' + String(cumSec).padStart(2, '0');

                const isHighlighted = idx >= highlightStart && idx <= highlightEnd;
                const bgClass = isHighlighted
                    ? 'bg-emerald-50 dark:bg-emerald-900/20 border-l-2 border-emerald-400'
                    : (idx % 2 === 0 ? 'bg-gray-50 dark:bg-gray-700/20' : '');

                html += '<div class="grid grid-cols-4 text-xs px-2 py-1 rounded ' + bgClass + '">';
                html += '<span class="text-gray-600 dark:text-gray-300 font-medium">' + (isLast ? (distKm.toFixed(2) + (unitsValue === 'mi' ? ' mi' : ' km')) : ((unitsValue === 'mi' ? 'mi ' : 'km ') + s.split)) + '</span>';
                html += '<span class="text-center font-medium text-gray-800 dark:text-gray-100">' + formatSplitPace(pace, unitsValue) + '</span>';
                html += '<span class="text-center text-gray-500 dark:text-gray-400">' + hr + '</span>';
                html += '<span class="text-right text-gray-400">' + cumStr + '</span>';
                html += '</div>';
            }
            html += '</div>';
            return html;
        }

        btns.forEach((card) => {
            card.addEventListener('click', async () => {
                const id = card.getAttribute('data-activity-id')!;
                const targetMeters = parseInt(card.getAttribute('data-target-meters') || '0', 10);
                const label = card.getAttribute('data-label') || '';
                const actName = card.getAttribute('data-activity-name') || '';

                if (titleEl) titleEl.textContent = label;
                if (subtitleEl) subtitleEl.textContent = actName;
                if (bodyEl) bodyEl.innerHTML = '<p class="text-sm text-gray-400 animate-pulse py-8 text-center">' + splitsLoadingLabel + '</p>';

                openModal();

                if (cache[id]) {
                    if (bodyEl) bodyEl.innerHTML = renderSplits(cache[id], targetMeters);
                    return;
                }

                try {
                    const res = await fetch('/api/activities/' + id);
                    if (!res.ok) throw new Error('HTTP ' + res.status);
                    const data = await res.json();
                    cache[id] = data.splits_metric || [];
                    if (bodyEl) bodyEl.innerHTML = renderSplits(cache[id], targetMeters);
                } catch (_e) {
                    if (bodyEl) bodyEl.innerHTML = '<p class="text-sm text-red-400 py-8 text-center">' + splitsErrorLabel + '</p>';
                }
            });

            card.addEventListener('keydown', (e) => {
                if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
                    e.preventDefault();
                    card.click();
                }
            });
        });
    }

    document.addEventListener('astro:page-load', initTimeBests);
</script>
