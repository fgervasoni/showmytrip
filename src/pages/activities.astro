---
import Layout from '../layouts/Layout.astro';
import {getStravaAthleteData} from '../lib/strava-data';
import {STRAVA_TOKEN_COOKIE} from '../lib/strava-auth';
import type {RunActivity, Units} from '../types';
import {formatDistance, formatDuration, formatPace, formatSpeed, formatDate} from '../lib/run-helpers';
import {t, getLocale, getUnits, LOCALE_COOKIE, UNITS_COOKIE, type Locale} from '../lib/i18n';

const locale = getLocale(Astro.cookies.get(LOCALE_COOKIE)?.value) as Locale;
const units = getUnits(Astro.cookies.get(UNITS_COOKIE)?.value) as Units;
const accessToken = Astro.cookies.get(STRAVA_TOKEN_COOKIE)?.value;

if (!accessToken) {
    return Astro.redirect('/');
}

const dashboardData = await getStravaAthleteData(accessToken);

const activities = Array.isArray(dashboardData?.recentActivities)
    ? (dashboardData.recentActivities as RunActivity[])
    : [];

// eslint-disable-next-line @typescript-eslint/no-unused-vars
const rateLimited = dashboardData?.rateLimited === true;
---

<Layout>
    <main class="min-h-screen bg-gray-50 py-8 px-4">
        <div class="max-w-4xl mx-auto">
            <header class="flex justify-between items-start gap-4 mb-8">
                <div>
                    <h1 class="text-3xl font-bold text-gray-900 m-0">{t(locale, 'recentActivities')}</h1>
                    <p class="text-gray-600 text-sm mt-1 m-0">{activities.length} {t(locale, 'activities').toLowerCase()}</p>
                </div>
                <a href="/"
                   class="px-4 py-2 bg-gray-600 text-white rounded font-semibold hover:bg-gray-700 transition whitespace-nowrap"
                   aria-label="Torna alla home">← {t(locale, 'dashboard')}</a>
            </header>

            {
                activities.length === 0 ? (
                        <div class="text-center text-gray-600 py-8">
                            <p>{t(locale, 'noActivitiesInPeriod')}</p>
                        </div>
                ) : (
                        <section class="space-y-4">
                            {activities.map((activity) => (
                                    <article
                                            class="bg-white border border-gray-200 rounded-lg p-5 hover:shadow-lg transition">
                                        <div class="flex items-start justify-between gap-3 mb-3">
                                            <h2 class="text-lg font-semibold text-gray-900 m-0">{activity.name ?? t(locale, 'noName')}</h2>
                                            <span class={`inline-block px-2 py-1 rounded text-xs font-bold uppercase whitespace-nowrap ${
                                                activity.type?.toLowerCase() === 'run'
                                                    ? 'bg-red-100 text-red-800'
                                                    : activity.type?.toLowerCase() === 'ride'
                                                        ? 'bg-blue-100 text-blue-800'
                                                        : activity.type?.toLowerCase() === 'swim'
                                                            ? 'bg-cyan-100 text-cyan-800'
                                                            : activity.type?.toLowerCase() === 'walk'
                                                                ? 'bg-yellow-100 text-yellow-800'
                                                                : 'bg-gray-100 text-gray-800'
                                            }`}>
									{activity.type ?? 'unknown'}
								</span>
                                        </div>

                                        <div class="text-sm text-gray-600 mb-4">
                                            <time datetime={activity.start_date}>
                                                {formatDate(activity.start_date)}
                                            </time>
                                        </div>

                                        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
                                            <div class="flex flex-col gap-1">
                                                <span class="text-xs font-bold text-gray-500 uppercase">{t(locale, 'distance')}</span>
                                                <span class="text-base font-bold text-gray-900">{formatDistance(activity.distance, units)}</span>
                                            </div>
                                            <div class="flex flex-col gap-1">
                                                <span class="text-xs font-bold text-gray-500 uppercase">{t(locale, 'time')}</span>
                                                <span class="text-base font-bold text-gray-900">{formatDuration(activity.moving_time)}</span>
                                            </div>
                                            <div class="flex flex-col gap-1">
                                                <span class="text-xs font-bold text-gray-500 uppercase">{t(locale, 'pace')}</span>
                                                <span class="text-base font-bold text-gray-900">{formatPace(activity.distance, activity.moving_time, units)}</span>
                                            </div>
                                            <div class="flex flex-col gap-1">
                                                <span class="text-xs font-bold text-gray-500 uppercase">{t(locale, 'avgPace')}</span>
                                                <span class="text-base font-bold text-gray-900">{formatSpeed(activity.average_speed)}</span>
                                            </div>
                                            {activity.total_elevation_gain && (
                                                    <div class="flex flex-col gap-1">
                                                        <span class="text-xs font-bold text-gray-500 uppercase">{t(locale, 'elevation')}</span>
                                                        <span class="text-base font-bold text-gray-900">{activity.total_elevation_gain}
                                                            m</span>
                                                    </div>
                                            )}
                                            {typeof activity.average_heartrate === 'number' && (
                                                    <div class="flex flex-col gap-1">
                                                        <span class="text-xs font-bold text-gray-500 uppercase">{t(locale, 'heartRate')}</span>
                                                        <span class="text-base font-bold text-gray-900">{Math.round(activity.average_heartrate)}
                                                            bpm</span>
                                                    </div>
                                            )}
                                            {typeof activity.kudos_count === 'number' && (
                                                    <div class="flex flex-col gap-1">
                                                        <span class="text-xs font-bold text-gray-500 uppercase">{t(locale, 'kudos')}</span>
                                                        <span class="text-base font-bold text-gray-900">{activity.kudos_count}</span>
                                                    </div>
                                            )}
                                        </div>
                                    </article>
                            ))}
                        </section>
                )
            }
        </div>
    </main>
</Layout>
<script is:inline define:vars={{rateLimited}}>
    if (rateLimited && window.__showRateLimitBanner) {
        window.__showRateLimitBanner();
    }
</script>
